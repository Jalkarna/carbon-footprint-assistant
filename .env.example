# ---- AI assistant (optional) ----
# The app works fully without these — the dashboard and insights are computed
# locally. Set these to enable the conversational AI assistant.
#
# DigitalOcean Gradient inference is OpenAI-compatible. The key is read ONLY on
# the server and is never exposed to the browser. Do NOT prefix it with
# NEXT_PUBLIC_ (that would ship it to the client).

# Required to enable the assistant:
DO_INFERENCE_API_KEY=

# Optional overrides (sensible defaults are used if omitted):
# DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
# DO_INFERENCE_MODEL=llama3.3-70b-instruct
# DO_INFERENCE_TIMEOUT_MS=30000
